#!/bin/bash
#SBATCH -A GOV113119
#SBATCH --partition=development
#SBATCH --job-name=bench_2n_32c
#SBATCH --nodes=2
#SBATCH --ntasks-per-node=32
#SBATCH -o run_2n_32c.log

SCRIPT_PATH=$(scontrol show job $SLURM_JOB_ID | awk -F= '/Command=/{print $2}')
SCRIPT_DIR=$(dirname "$SCRIPT_PATH")
cd "$SCRIPT_DIR"

bash ./run.sh
