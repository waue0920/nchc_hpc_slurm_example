#!/bin/bash
#SBATCH -A GOV113119
#SBATCH --partition=development
#SBATCH --job-name=bench_16n_4c
#SBATCH --nodes=16
#SBATCH --ntasks-per-node=4
#SBATCH -o run_16n_4c.log

SCRIPT_PATH=$(scontrol show job $SLURM_JOB_ID | awk -F= '/Command=/{print $2}')
SCRIPT_DIR=$(dirname "$SCRIPT_PATH")
cd "$SCRIPT_DIR"

bash ./run.sh
