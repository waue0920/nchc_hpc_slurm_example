#!/bin/bash
#SBATCH --job-name=BuildMiniW
#SBATCH --nodes=1
#SBATCH --cpus-per-task=4
#SBATCH --partition=gtest
#SBATCH --output=z_build_openacc.log

SCRIPT_PATH=$(scontrol show job $SLURM_JOB_ID | awk -F= '/Command=/{print $2}')
SCRIPT_DIR=$(dirname "$SCRIPT_PATH")
cd "$SCRIPT_DIR/.."

# тЉ╝тЈФ sh ТфћтЪиУАїт»джџЏуџёуиеУГ»тІЋСйю
srun --label bash setup_scripts/2_build_openacc.sh
